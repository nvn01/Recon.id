# Copy this file to ".env" for local development.
# Keep scraper-specific source URLs and cadence config inside scraper/.

POSTGRES_DB=recon_dev
POSTGRES_USER=recon
POSTGRES_PASSWORD=recon_dev_password

DATABASE_URL="postgresql://recon:recon_dev_password@localhost:5432/recon_dev"

# Optional: use this later for a narrower scraper DB role. Falls back to DATABASE_URL when empty.
SCRAPER_DATABASE_URL=

# NVIDIA API Catalog / NIM parser. Keep the real key only in local env or a secret manager.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_PARSE_MODEL="nvidia/nemotron-3-nano-30b-a3b"
