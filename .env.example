# Copy this file to ".env" for local development.
# Keep scraper-specific source URLs and cadence config inside scraper/.

POSTGRES_DB=recon_dev
POSTGRES_USER=recon
POSTGRES_PASSWORD=recon_dev_password

DATABASE_URL="postgresql://recon:recon_dev_password@localhost:5432/recon_dev"

# Optional: use this later for a narrower scraper DB role. Falls back to DATABASE_URL when empty.
SCRAPER_DATABASE_URL=

# Scraper egress defaults to direct internet access. Proxy/VPN paths are opt-in
# guardrails for later operations, not the default anti-block strategy.
SCRAPER_EGRESS_MODE=direct
SCRAPER_ALLOW_PROXY=false
SCRAPER_PROXY_URL=
SCRAPER_ALLOW_VPN=false

# NVIDIA API Catalog / NIM parser. Keep the real key only in local env or a secret manager.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_PARSE_MODEL="nvidia/nemotron-3-nano-30b-a3b"

# Deployment-only examples. Staging binds to the Debian VM's Tailscale IP so
# ubserver1 Traefik/Cloudflare can proxy to it without exposing PostgreSQL.
WEB_BIND=100.100.20.3
WEB_PORT=3000
WEB_IMAGE_TAG=1.0.0
SCRAPER_IMAGE_TAG=1.0.0
TRAEFIK_HOSTNAME=recon.example.com
