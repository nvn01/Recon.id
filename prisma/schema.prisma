generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingPlatform {
  REDDIT    @map("reddit")
  INSTAGRAM @map("instagram")
  FACEBOOK  @map("facebook")

  @@map("listing_platform")
}

enum ListingStatus {
  AVAILABLE @map("available")
  SOLD      @map("sold")
  UNKNOWN   @map("unknown")

  @@map("listing_status")
}

model Listing {
  id             String          @id @default(cuid())
  platform       ListingPlatform
  sourceUrl      String          @unique @map("source_url")
  externalId     String?         @map("external_id")
  title          String
  description    String
  category       String?
  brand          String?
  price          Int?
  locationTexts  String[]        @default([]) @map("location_texts")
  conditionText  String?         @map("condition_text")
  sellerName     String?         @map("seller_name")
  status         ListingStatus   @default(UNKNOWN)
  postedAt       DateTime?       @map("posted_at")
  firstFetchedAt DateTime        @default(now()) @map("first_fetched_at")
  lastFetchedAt  DateTime        @default(now()) @map("last_fetched_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  images         ListingImage[]

  @@index([platform])
  @@index([status])
  @@index([category])
  @@index([brand])
  @@index([lastFetchedAt])
  @@index([price])
  @@map("listings")
}

model ListingImage {
  id          String    @id @default(cuid())
  listingId   String    @map("listing_id")
  sourceUrl   String    @map("source_url")
  cachedUrl   String?   @map("cached_url")
  storageKey  String?   @map("storage_key")
  contentHash String?   @map("content_hash")
  contentType String?   @map("content_type")
  byteSize    Int?      @map("byte_size")
  cachedAt    DateTime? @map("cached_at")
  position    Int
  altText     String?   @map("alt_text")
  createdAt   DateTime  @default(now()) @map("created_at")
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, position])
  @@index([listingId])
  @@map("listing_images")
}
